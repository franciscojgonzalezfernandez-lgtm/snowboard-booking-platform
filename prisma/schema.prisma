
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Locale {
  en
  de
  es
}

enum Role {
  student
  instructor
  admin
}

enum Duration {
  ONE_HOUR
  TWO_HOURS
  INTENSIVE
  FULL_DAY
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT_FREESTYLE
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED_BY_USER
  CANCELLED_BY_OPS
  PAYMENT_FAILED
}

enum AvailabilityKind {
  AVAILABLE
  BLOCKED
}

enum CreditReason {
  USER_CANCEL
  OPS_CANCEL
}

enum CreditStatus {
  ACTIVE
  LOCKED
  USED
  EXPIRED
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String?
  image         String?
  locale        Locale   @default(en)
  roles         Role[]   @default([student])
  phone         String?
  preferences   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions       Session[]
  accounts       Account[]
  instructor     Instructor?
  bookings       Booking[]
  accountCredits AccountCredit[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Instructor {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  photo                  String?
  bio                    String?  @db.Text
  specialties            String[]
  languages              Locale[]
  active                 Boolean  @default(true)
  acceptsSameDayIfBooked Boolean  @default(false)
  calendarConnected      Boolean  @default(false)
  googleRefreshToken     String?
  createdAt              DateTime @default(now())

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  tips               Tip[]
}

model AvailabilityBlock {
  id            String           @id @default(cuid())
  instructorId  String
  startDateTime DateTime
  endDateTime   DateTime
  kind          AvailabilityKind

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId, startDateTime])
  @@index([startDateTime, endDateTime])
}

/// Season holds operational config for a booking period (start/end dates,
/// anchor times, operating hours). No FK from Booking → Season on purpose:
/// the booking engine derives the active Season from `Booking.date` at query
/// time, so a FK would be redundant and would require a backfill if season
/// boundaries ever shift.
model Season {
  id                  String   @id @default(cuid())
  name                String
  startDate           DateTime @db.Date
  endDate             DateTime @db.Date
  active              Boolean  @default(true)
  /// 24h "HH:MM" strings, e.g. ["09:00","11:00","13:00","15:00"].
  /// Order does not matter; the booking engine sorts.
  anchorTimes         String[]
  /// 24h "HH:MM" — earliest start time a class may begin in this season.
  operatingHoursStart String
  /// 24h "HH:MM" — latest end time a class may end in this season.
  operatingHoursEnd   String

  @@index([active, startDate, endDate])
}

model Booking {
  id                    String        @id @default(cuid())
  bookerId              String
  instructorId          String
  date                  DateTime      @db.Date
  anchorTime            String
  duration              Duration
  language              Locale
  status                BookingStatus
  totalPriceCents       Int
  stripePaymentIntentId String?       @unique
  icsUid                String        @unique
  googleEventId         String?
  notes                 String?       @db.Text
  cancelledByUserAt     DateTime?
  cancelledByOpsAt      DateTime?
  opsReason             String?
  reminder24hSentAt     DateTime?
  postClassEmailSentAt  DateTime?
  createdAt             DateTime      @default(now())

  booker          User            @relation(fields: [bookerId], references: [id], onDelete: Restrict)
  instructor      Instructor      @relation(fields: [instructorId], references: [id], onDelete: Restrict)
  attendees       Attendee[]
  tip             Tip?
  creditsSourced  AccountCredit[] @relation("CreditSource")
  creditsRedeemed AccountCredit[] @relation("CreditRedemption")
  creditsLocking  AccountCredit[] @relation("CreditLock")

  @@index([bookerId, status])
  @@index([instructorId, date])
  @@index([date, status])
}

/// Attendee = a person attending a class. The booker (Booking.bookerId)
/// is NOT automatically an attendee — e.g. a parent paying for kids.
/// At most ONE attendee per booking may have isBooker = true; this is
/// enforced by a partial unique index added in a follow-up migration
/// (see `20260518090000_attendee_booker_unique`).
model Attendee {
  id        String   @id @default(cuid())
  bookingId String
  name      String
  birthDate DateTime @db.Date
  level     Level
  isBooker  Boolean  @default(false)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model AccountCredit {
  id                String       @id @default(cuid())
  userId            String
  amountCents       Int
  sourceBookingId   String
  usedOnBookingId   String?
  lockedByBookingId String?
  reason            CreditReason
  status            CreditStatus
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime     @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceBooking   Booking  @relation("CreditSource", fields: [sourceBookingId], references: [id])
  usedOnBooking   Booking? @relation("CreditRedemption", fields: [usedOnBookingId], references: [id])
  lockedByBooking Booking? @relation("CreditLock", fields: [lockedByBookingId], references: [id])

  @@index([userId, status])
  @@index([status, expiresAt])
}

model Tip {
  id                    String   @id @default(cuid())
  bookingId             String   @unique
  instructorId          String
  amountCents           Int
  stripePaymentIntentId String   @unique
  paidAt                DateTime
  requestEmailSentAt    DateTime

  booking    Booking    @relation(fields: [bookingId], references: [id])
  instructor Instructor @relation(fields: [instructorId], references: [id])

  @@index([instructorId, paidAt])
}

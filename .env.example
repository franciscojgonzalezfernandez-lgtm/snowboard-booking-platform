DATABASE_URL=
DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_ID=
GOOGLE_SECRET=

# Email / Resend
RESEND_API_KEY=
EMAIL_FROM="Ride Flumserberg <hello@rideflumserberg.ch>"
EMAIL_REPLY_TO=
EMAIL_TEST_RECIPIENT=

# Sentry
# Public DSN — also exposed at build time via instrumentation-client.ts
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (same value as NEXT_PUBLIC_SENTRY_DSN; safe public)
SENTRY_DSN=
# Source-maps upload token (also stored in .env.sentry-build-plugin, gitignored)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Vercel Deployment Protection — bypass token for Playwright/CI against preview URLs.
# Auto-injected by Vercel into its own runtime/build env when generated in the dashboard.
# Must be set explicitly in GitHub Actions secrets and local .env.local for E2E
# runs targeting *.vercel.app previews. Rotate via Vercel dashboard if leaked.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Stripe (F-018)
# Test-mode keys live under Dashboard → Developers → API keys (toggle "Test mode").
# Publishable is safe in the client bundle; Secret is server-only.
# Live-mode keys land after Stripe finishes account verification — keep them
# in Vercel Production scope and never in this repo.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Endpoint signing secret. Two values — one per environment:
#   - Production: Dashboard → Developers → Webhooks → endpoint
#     "https://rideflumserberg.ch/api/webhooks/stripe" → "Signing secret"
#   - Local dev:  `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#     prints a `whsec_*` for the CLI session. Use that in `.env.local`.
STRIPE_WEBHOOK_SECRET=

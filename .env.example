DATABASE_URL=
DIRECT_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (login via Better Auth + Calendar connect F-074)
GOOGLE_ID=
GOOGLE_SECRET=

# Calendar token encryption (ADR-007 / F-074): 32-byte key, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Set in Vercel (Production + Preview) + local .env.local. See lib/calendar/README.md.
ENCRYPTION_KEY=

# Email / Resend
RESEND_API_KEY=
EMAIL_FROM="Ride Flumserberg <hello@rideflumserberg.ch>"
EMAIL_REPLY_TO=
EMAIL_TEST_RECIPIENT=

# Sentry
# Public DSN — also exposed at build time via instrumentation-client.ts
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (same value as NEXT_PUBLIC_SENTRY_DSN; safe public)
SENTRY_DSN=
# Source-maps upload token (also stored in .env.sentry-build-plugin, gitignored)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Vercel Deployment Protection — bypass token for Playwright/CI against preview URLs.
# Auto-injected by Vercel into its own runtime/build env when generated in the dashboard.
# Must be set explicitly in GitHub Actions secrets and local .env.local for E2E
# runs targeting *.vercel.app previews. Rotate via Vercel dashboard if leaked.
VERCEL_AUTOMATION_BYPASS_SECRET=

# Stripe (F-018)
# Test-mode keys live under Dashboard → Developers → API keys (toggle "Test mode").
# Publishable is safe in the client bundle; Secret is server-only.
# Live-mode keys land after Stripe finishes account verification — keep them
# in Vercel Production scope and never in this repo.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Endpoint signing secret. Two values — one per environment:
#   - Production: Dashboard → Developers → Webhooks → endpoint
#     "https://rideflumserberg.ch/api/webhooks/stripe" → "Signing secret"
#   - Local dev:  `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#     prints a `whsec_*` for the CLI session. Use that in `.env.local`.
STRIPE_WEBHOOK_SECRET=

# Vercel Cron (F-048)
# Shared secret enforced by /api/cron/* route handlers. Vercel injects the header
# `Authorization: Bearer ${CRON_SECRET}` automatically when crons are configured
# in vercel.json. Set per-environment in Vercel dashboard; rotate if leaked.
CRON_SECRET=

# Post-class email CTAs (F-048)
# Both optional — CTAs degrade gracefully when null (link omitted from template).
# Google Place ID for review CTA (D-PLACE in PRD §Decisions). Sprint 5 will reopen.
GOOGLE_PLACE_ID=
# Direct tip URL (SumUp / TWINT request). 100% to instructor — see ADR-008.
INSTRUCTOR_TIP_URL=

# Vercel Blob (F-073)
# Auto-provisioned by Vercel when a Blob store is connected to the project
# (Dashboard → Storage → Create → Blob → PUBLIC access mode → Connect to
# project, mark Production + Preview + Development). Pull locally with
# `vercel env pull .env.local --environment=development`.
# F-073 photo upload action is runtime-gated on BLOB_READ_WRITE_TOKEN — when
# the var is missing, the uploader UI shows an inline notice and disables the
# controls instead of failing the request.
BLOB_READ_WRITE_TOKEN=
# Auto-injected metadata. Not consumed by the app today; kept in sync with the
# Vercel-pulled .env.local so the example matches what new devs actually see.
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=
